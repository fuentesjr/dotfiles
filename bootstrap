#!/bin/bash
# Run by codespaces after starting
set -euo pipefail

cd "$(dirname "$0")"

backup() {
  local src="$1"
  if [[ -f "$src" && ! -L "$src" ]]; then
    cp "$src" "${src}.stock"
    echo "Backed up $src"
  fi
}

backup "$HOME/.gitconfig"
backup "$HOME/.bashrc"
backup "$HOME/.zshrc"

echo "Installing packages..."
brew install fzf figlet ripgrep fd-find stow neovim

echo "Installing ctags..."
brew install --HEAD universal-ctags/universal-ctags/universal-ctags
script/build-ctags > /dev/null 2>&1

echo "Stowing dotfiles..."
stow --target="$HOME" zsh git vim nvim jj tmux
